# --- Supabase ----------------------------------------------------------------
# Project Settings → API в дашборде Supabase.

# URL проекта, напр. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Публичный anon-ключ (безопасен для клиента; вся защита — на RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role ключ — ТОЛЬКО на сервере. Нужен для приглашения участников
# (поиск пользователя по email через Admin API). Никогда не отдавайте клиенту.
SUPABASE_SERVICE_ROLE_KEY=
